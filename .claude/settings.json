{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-build.sh",
            "timeout": 300,
            "statusMessage": "Verifying build..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(stat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(touch:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm -rf out/build/*)",
      "Bash(rm -rf build/*)",
      "Bash(cmake:*)",
      "Bash(make:*)",
      "Bash(ninja:*)",
      "Bash(cmake --build out/build)",
      "Bash(cmake --build out/build --config RelWithDebInfo)",
      "Bash(cmake --build out/build --config Release)",
      "Bash(ctest:*)",
      "Bash(./aihub_tests.exe:*)",
      "Bash(./tests/Release/aihub_tests.exe:*)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ping:*)",
      "mcp__web-search-prime__web_search_prime"
    ]
  }
}
